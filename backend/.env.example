# Copy to .env and fill values
APP_VERSION=0.1.0

# Clarifai (optional). If absent, falls back to static prediction
CLARIFAI_API_KEY=
# Clarifai model id for food recognition
CLARIFAI_MODEL_ID=food-item-recognition

# Google Maps Places (optional). Needed for nearby restaurants
GOOGLE_MAPS_API_KEY=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
